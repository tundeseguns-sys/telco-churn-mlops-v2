# -----------------------------------
# Python virtual environments
# -----------------------------------
.venv/
venv/
env/

# -----------------------------------
# Python cache and compiled files
# -----------------------------------
__pycache__/
*.py[cod]
*$py.class

# -----------------------------------
# Packaging and build output
# -----------------------------------
build/
dist/
*.egg-info/
.eggs/

# -----------------------------------
# Testing and coverage
# -----------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# -----------------------------------
# Linting and type-checking caches
# -----------------------------------
.ruff_cache/
.mypy_cache/

# -----------------------------------
# Jupyter temporary files
# -----------------------------------
.ipynb_checkpoints/

# -----------------------------------
# VS Code and IDE settings
# -----------------------------------
.vscode/
.idea/

# -----------------------------------
# Operating-system files
# -----------------------------------
.DS_Store
Thumbs.db

# -----------------------------------
# Environment variables and secrets
# -----------------------------------
.env
.env.*
!.env.example

# -----------------------------------
# Logs
# -----------------------------------
*.log
logs/

# -----------------------------------
# MLflow local files
# -----------------------------------
mlruns/
mlartifacts/

# -----------------------------------
# Saved model artifacts
# -----------------------------------
models/*
!models/.gitkeep

# -----------------------------------
# Generated reports
# -----------------------------------
reports/figures/*
!reports/figures/.gitkeep

# -----------------------------------
# Project datasets
# Raw, interim and processed data are
# not committed to GitHub.
# -----------------------------------
data/raw/*
!data/raw/.gitkeep

data/interim/*
!data/interim/.gitkeep

data/processed/*
!data/processed/.gitkeep